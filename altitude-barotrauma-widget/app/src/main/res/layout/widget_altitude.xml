<?xml version="1.0" encoding="utf-8"?>
<!--
    위젯 레이아웃 개선:
    - 배경색 하드코딩 제거 → @android:color/background_dark / system_accent 대응
    - 텍스트 색상 RemoteViews.setTextColor()로 동적 처리
    - 5분 누적 변화량 + 직전 30초 변화량 둘 다 표시
    - 여백 및 텍스트 크기 정비
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 현재 고도 -->
    <TextView
        android:id="@+id/text_altitude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/altitude_measuring"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:letterSpacing="0.01" />

    <!-- 5분 누적 변화량 / 30초 변화량 -->
    <TextView
        android:id="@+id/text_altitude_change"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/change_no_data"
        android:textSize="12sp"
        android:textColor="#CCFFFFFF"
        android:layout_marginTop="3dp" />

    <!-- 행동 추천 (위험도에 따라 색상 동적 변경) -->
    <TextView
        android:id="@+id/text_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_initializing"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:layout_marginTop="7dp" />

</LinearLayout>
