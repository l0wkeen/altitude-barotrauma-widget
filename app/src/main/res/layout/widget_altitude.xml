<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 상단: 라벨 + 고도 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 이어 아이콘 + 라벨 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🦻 ALTITUDE"
            android:textSize="9sp"
            android:textColor="#80FFFFFF"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <!-- 현재 고도 (크게) -->
        <TextView
            android:id="@+id/text_altitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/altitude_measuring"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#40FFFFFF" />

    <!-- 중단: 변화량 -->
    <TextView
        android:id="@+id/text_altitude_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/change_no_data"
        android:textSize="11sp"
        android:textColor="#B3FFFFFF"
        android:letterSpacing="0.02"
        android:layout_marginBottom="8dp" />

    <!-- 하단: 행동 추천 (배경 포함, 강조) -->
    <TextView
        android:id="@+id/text_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_initializing"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="@drawable/action_bg" />

</LinearLayout>
