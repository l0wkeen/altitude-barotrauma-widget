<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_label"
            android:textSize="10sp"
            android:textColor="#99FFFFFF" />

        <TextView
            android:id="@+id/text_altitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/altitude_measuring"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF" />
    </LinearLayout>

    <!-- 구분선: View 대신 TextView 사용 (RemoteViews 제약) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#33FFFFFF" />

    <TextView
        android:id="@+id/text_altitude_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/change_no_data"
        android:textSize="12sp"
        android:textColor="#CCFFFFFF"
        android:layout_marginBottom="5dp" />

    <TextView
        android:id="@+id/text_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_initializing"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:gravity="center_horizontal" />

</LinearLayout>